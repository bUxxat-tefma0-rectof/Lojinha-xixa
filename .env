# Configurações do Bot
TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_ADMIN_TOKEN=seu_admin_token_aqui
CALLMEBOT_API_KEY=sua_api_key_aqui
CALLMEBOT_PHONE=seu_telefone_aqui

# Configurações do WhatsApp Business API (opcional)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_ID=seu_phone_id_aqui
WHATSAPP_ACCESS_TOKEN=seu_access_token_aqui

# Configurações do Bot
BOT_NAME=JOÃOZINHO STORE BOT
ADMIN_ID=8206910765
MIN_RECHARGE=5
MAX_RECHARGE=1000
PIX_EXPIRATION_MINUTES=30
AFFILIATE_COMMISSION=0.10

# Configurações do Banco de Dados
DATABASE_FILE=joaozinho_store.db

# Configurações de Suporte
SUPPORT_GROUP_LINK=https://t.me/seu_grupo_suporte
SUPPORT_PHONE=+5511999999999

# Configurações de Segurança
FLOOD_PROTECTION_ENABLED=true
FLOOD_TIMEOUT_SECONDS=3
MAX_MESSAGES_PER_MINUTE=20

# Configurações de Notificações
ENABLE_STOCK_NOTIFICATIONS=true
ENABLE_PAYMENT_NOTIFICATIONS=true
ENABLE_DELIVERY_NOTIFICATIONS=true

# Configurações de Backup
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# Configurações do Admin Panel
ADMIN_PANEL_PORT=5000
ADMIN_PANEL_HOST=0.0.0.0
ADMIN_PANEL_SECRET_KEY=sua_chave_secreta_aqui